def create_polybius_square(key):
    alphabet = "abcdefghiklmnopqrstuvwxyz"  
    key = key.lower().replace("j", "i")

    square = ""
    for c in key:
        if c not in square and c in alphabet:
            square += c

    for c in alphabet:
        if c not in square:
            square += c

    matrix = [list(square[i:i+5]) for i in range(0, 25, 5)]
    return matrix


def find_position(matrix, char):
    if char == 'j':
        char = 'i'
    for i in range(5):
        for j in range(5):
            if matrix[i][j] == char:
                return i, j


def bifid_encrypt(text, key):
    matrix = create_polybius_square(key)

    text = text.lower().replace("j", "i")
    text = "".join([c for c in text if c.isalpha()])

    rows = []
    cols = []

    for char in text:
        r, c = find_position(matrix, char)
        rows.append(r)
        cols.append(c)

    combined = rows + cols

    ciphertext = ""
    for i in range(0, len(combined), 2):
        r = combined[i]
        c = combined[i+1]
        ciphertext += matrix[r][c]

    return ciphertext


text = "sot eshte dite e mire"
key = "crypto"

encrypted = bifid_encrypt(text, key)
print("Encrypted:", encrypted)
