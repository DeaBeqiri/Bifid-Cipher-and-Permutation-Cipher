def bifid_decrypt(ciphertext, key):
    alphabet = "abcdefghiklmnopqrstuvwxyz"  # pa j
    key = key.lower().replace("j", "i")
    ciphertext = ciphertext.lower().replace("j", "i")

    
    square = ""
    for c in key:
        if c not in square and c in alphabet:
            square += c
    for c in alphabet:
        if c not in square:
            square += c

    
    pos = {}
    for i in range(5):
        for j in range(5):
            pos[square[i*5 + j]] = (i, j)

    coords = []

  
    for c in ciphertext:
        if c.isalpha():
            r, c2 = pos[c]
            coords.append(r)
            coords.append(c2)

    
    half = len(coords) // 2
    rows = coords[:half]
    cols = coords[half:]

    
    plaintext = ""
    for i in range(len(rows)):
        r = rows[i]
        c = cols[i]
        plaintext += square[r*5 + c]

    return plaintext



text = "sot eshte dite"
key = "crypto"

enc = bifid_encrypt(text, key)
dec = bifid_decrypt(enc, key)

print("Encrypted:", enc)
print("Decrypted:", dec)
